BETWEEN and NOT BETWEEN Operator
Used to select values within a range

Syntax
SELECT column_name FROM table_name WHERE column BETWEEN value1 AND value2;

1️⃣ Employees with salary between 25000 and 50000
SELECT * FROM EMP_INFO WHERE SAL BETWEEN 25000 AND 50000;

2️⃣ Employees with salary between 25000 and 60000 (excluding 60000)
SELECT NAME, SAL FROM EMP_INFO WHERE SAL BETWEEN 25000 AND 59999;

3️⃣ Employees who joined in 2019
SELECT * FROM EMP_INFO WHERE JDATE BETWEEN '2019-01-01' AND '2019-12-31';

4️⃣ Employees who did NOT join in 2019
SELECT * FROM EMP_INFO WHERE JDATE NOT BETWEEN '2019-01-01' AND '2019-12-31';

IN and NOT IN Operator
Used to match multiple specific values.

Syntax
SELECT column_name FROM table_name WHERE column IN(value1,value2);

1️⃣ Employees who joined on 26-Jan-2019 or 16-Aug-2019
SELECT * FROM EMP_INFO WHERE JDATE IN ('2019-01-26','2019-08-16');

2️⃣ Employees who did NOT join on those dates
SELECT * FROM EMP_INFO WHERE JDATE NOT IN ('2019-01-26','2019-08-16');

3️⃣ Employees whose salary is 25000, 50000, or 75000
SELECT * FROM EMP_INFO WHERE SAL IN (25000,50000,75000);

LIKE and NOT LIKE Operator
Used for pattern matching.

Wildcard characters:
Symbol	Meaning
_	exactly one character
%	zero or many characters

1️⃣ Employees with 4-digit salary
SELECT *  FROM EMP_INFO WHERE SAL LIKE '____';

2️⃣ Employees NOT having 4-digit salary
SELECT * FROM EMP_INFO WHERE SAL NOT LIKE '____';

3️⃣ Employees whose salary starts with 5
SELECT * FROM EMP_INFO WHERE SAL LIKE '5%';

4️⃣ Employees whose name starts with 'S'
SELECT * FROM EMP_INFO WHERE NAME LIKE 'S%';

5️⃣ Employees whose name ends with 'a'
SELECT * FROM EMP_INFO WHERE NAME LIKE '%a';

6️⃣ Employees whose name ends with 'nka'
SELECT * FROM EMP_INFO WHERE NAME LIKE '%nka';

7️⃣ Employees whose name starts with 'P' and ends with 'a'
SELECT * FROM EMP_INFO WHERE NAME LIKE 'P%a';

8️⃣ Employees whose name contains 'u'
SELECT * FROM EMP_INFO WHERE NAME LIKE '%u%';

9️⃣ Employees with name of 8 characters and second letter 'u'
SELECT * FROM EMP_INFO WHERE NAME LIKE '_u______';

🔟 Employees who joined in 2020
SELECT * FROM EMP_INFO WHERE JDATE LIKE '2020%';

1️⃣ Employees whose name starts with 'S' and has exactly 4 characters
SELECT * FROM EMP_INFO WHERE NAME LIKE 'S___';

IS NULL and IS NOT NULL Operator
Used to check missing values.
NULL means no value stored.

1️⃣ Employees whose EMAIL is NULL
SELECT * FROM EMP_INFO WHERE EMAIL IS NULL;

2️⃣ Employees whose EMAIL and ADDRESS are NULL
SELECT * FROM EMP_INFO WHERE EMAIL IS NULL AND ADDRESS IS NULL;

3️⃣ Employees whose EMAIL is NOT NULL
SELECT * FROM EMP_INFO WHERE EMAIL IS NOT NULL;