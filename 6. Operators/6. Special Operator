1. Create Database
CREATE DATABASE CompanyDB;

2. Use Database
USE CompanyDB;

3. Create Table
CREATE TABLE EMP_INFO (
    EMP_ID INT PRIMARY KEY,
    NAME VARCHAR(50),
    SAL INT,
    JDATE DATE,
    EMAIL VARCHAR(100),
    ADDRESS VARCHAR(255)
);

